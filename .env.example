# Supplement Engine — Environment Variables
# Copy this to .env and fill in values

# ── Database ────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=supplement_engine_dev

POSTGRES_PASSWORD=devpassword
POSTGRES_DSN=postgresql+asyncpg://supplement:devpassword@postgres:5432/supplement_db

REDIS_URL=redis://redis:6379/0

# ── Engine tuning ────────────────────────────────────────────────────────────
MAX_RECOMMENDATIONS=8
DRS_THRESHOLD=0.35
MIN_CONFIDENCE=0.40

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info

# Phase 2a: inline patient JSON on POST /v1/recommendations (dev/Phase 1 compat)
# Set to 0 in production; use patient_id only
ALLOW_INLINE_PATIENT=1

# ── Production API auth (Phase 2b-prod M1) ───────────────────────────────────
# Dev default: auth off. Prod overlay (docker-compose.prod.yml) sets these.
REQUIRE_API_KEY=0
# Comma-separated keys when REQUIRE_API_KEY=1
# API_KEYS=pilot-dev-key-change-me,rotate-in-vault

# ── Frontend (Next.js clinician console) ─────────────────────────────────────
ENGINE_API_URL=http://localhost:8000
ENGINE_API_KEY=dev-key
# Optional HTTP basic auth for the console (recommended for pilot with real PHI)
# CONSOLE_AUTH_USER=clinician
# CONSOLE_AUTH_PASSWORD=change-me

# ── Event streaming (optional — not needed for Docker pilot) ─────────────────
# KAFKA_ENABLED=0
# When you add real-time ingestion later: docker compose --profile ingestion up -d